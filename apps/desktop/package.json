{
  "name": "mega-vault-viewer-desktop",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev:web": "vite --host 127.0.0.1 --port 1420",
    "build:web": "vite build",
    "build": "tsc --noEmit && vite build",
    "test": "node --test src/*.test.ts && tsc --noEmit",
    "desktop:build": "node ../../scripts/tauri-build.mjs",
    "desktop:build:macos": "TAURI_BUNDLES=dmg,app node ../../scripts/tauri-build.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "node ../../scripts/tauri-build.mjs",
    "tauri:build:macos": "TAURI_BUNDLES=dmg,app node ../../scripts/tauri-build.mjs",
    "tauri:build:windows": "tauri build --bundles nsis,msi",
    "tauri:build:windows:gnu": "tauri build --target x86_64-pc-windows-gnu --bundles nsis,msi"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.0",
    "vite": "^7.2.7",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.0"
  }
}
