{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mega Vault Viewer",
  "version": "0.1.0",
  "identifier": "com.megavaultviewer.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mega Vault Viewer",
        "width": 1180,
        "height": 760,
        "minWidth": 860,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
